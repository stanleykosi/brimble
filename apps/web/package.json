{
  "name": "@brimble/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @brimble/contracts run build",
    "dev": "vite",
    "pregenerate-routes": "pnpm --filter @brimble/contracts run build",
    "generate-routes": "tsr generate",
    "prebuild": "pnpm --filter @brimble/contracts run build",
    "build": "pnpm run generate-routes && vite build",
    "pretypecheck": "pnpm --filter @brimble/contracts run build",
    "typecheck": "pnpm run generate-routes && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@brimble/contracts": "workspace:*",
    "@tanstack/react-query": "^5.76.2",
    "@tanstack/react-router": "^1.120.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.120.5",
    "@tanstack/router-plugin": "^1.120.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
